# SkillSync Server — Production Environment
# Set these in Vercel/Railway dashboard (never commit real values)

NODE_ENV=production
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/skillsync

JWT_SECRET=generate-a-long-random-string
JWT_EXPIRES_IN=1d
JWT_REFRESH_TOKEN_SECRET=generate-another-long-random-string
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

SESSION_SECRET=random-session-secret
CLIENT_URL=https://your-client-app.vercel.app

GROQ_API_KEY=your_groq_api_key

IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASS=
